# Optional: if you keep this in a non-default location:
# GOOGLE_METRICS_ENV_FILE=/absolute/path/to/.env.google-metrics

# Date window is set via CLI: --days 30

# ---------------------------
# Google Analytics 4 (GA4)
# ---------------------------
# Example: 123456789
GA4_PROPERTY_ID=
# Optional auto-discovery hint if GA4_PROPERTY_ID is unset.
# Example: G-ABC123XYZ9
GA4_MEASUREMENT_ID=

# ---------------------------
# Google AdSense
# ---------------------------
# Optional; if blank, script uses the first accessible account.
# Example: accounts/pub-1234567890123456
ADSENSE_ACCOUNT=

# ---------------------------
# Google Ads API
# ---------------------------
# Required for Google Ads queries:
# Example: 1234567890 (or 123-456-7890)
GOOGLE_ADS_CUSTOMER_ID=

# Required for Google Ads API requests:
GOOGLE_ADS_DEVELOPER_TOKEN=

# Optional but recommended when using manager accounts (MCC).
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Optional OAuth refresh token flow (if you do NOT want ADC for Google Ads).
# If all 3 below are set, script uses them first.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ---------------------------
# Google Cloud Billing -> BigQuery export (Gemini spend breakdown)
# ---------------------------
# Example: my-billing-project.billing_export.gcp_billing_export_v1_ABC123_DEF456
GCP_BILLING_EXPORT_TABLE=

# Optional query project override for BigQuery jobs.
GCP_BILLING_QUERY_PROJECT=
