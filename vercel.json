{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.thetrackerapp.io"
        }
      ],
      "destination": "https://thetrackerapp.io/:path*",
      "permanent": true
    },
    {
      "source": "/affiliate/dashboard",
      "destination": "https://dashboard.thetrackerapp.io/dashboard?view=affiliate",
      "permanent": false
    },
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/signup",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "dashboard.thetrackerapp.io"
        }
      ],
      "destination": "/dashboard",
      "permanent": false
    },
    {
      "source": "/affiliate/:path*",
      "has": [
        {
          "type": "host",
          "value": "dashboard.thetrackerapp.io"
        }
      ],
      "destination": "/dashboard?view=affiliate",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/dashboard-endpoints", "destination": "/api/dashboard-endpoints" },
    { "source": "/@:username", "destination": "/user" },
    { "source": "/", "destination": "/api/home" },
    { "source": "/blog/:slug", "destination": "/blog-post" },
    { "source": "/blog/rss.xml", "destination": "/blog/rss.xml" },
    { "source": "/api/stream-url", "destination": "/api/control?action=stream-video" }
  ],
  "functions": {
    "api/home.js": {
      "includeFiles": "dist/index.html"
    }
  }
}
